#include <metal_stdlib>
using namespace metal;

// Mirrors the layout in FluidShaders.metal — keep these fields in sync.
struct FluidUniforms {
    float2 resolution;
    float2 touch;
    float2 touchVelocity;
    float touchActive;
    float dt;
    float viscosity;
    float diffusion;
    float time;
    float3 tint;
};

// MARK: - Hash / noise utilities (prefix __scene___ to avoid name collisions across shader files)

static float __scene___hash(float2 p) {
    float3 p3 = fract(float3(p.xyx) * 0.1031);
    p3 += dot(p3, p3.yzx + 33.33);
    return fract((p3.x + p3.y) * p3.z);
}

static float __scene___noise(float2 p) {
    float2 i = floor(p);
    float2 f = fract(p);
    f = f * f * (3.0 - 2.0 * f);
    float a = __scene___hash(i);
    float b = __scene___hash(i + float2(1, 0));
    float c = __scene___hash(i + float2(0, 1));
    float d = __scene___hash(i + float2(1, 1));
    return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
}

static float __scene___fbm(float2 p, int octaves) {
    float v = 0.0;
    float a = 0.5;
    for (int i = 0; i < octaves; i++) {
        v += a * __scene___noise(p);
        p *= 2.0;
        a *= 0.5;
    }
    return v;
}

// MARK: - Render kernel
//
// Entry point name MUST match TextureType.kernelName for this scene
// (e.g. `waves_render` for TextureType.waves). The Metal pipeline lookup
// in FluidMetalView is keyed by this string.

kernel void __scene___render(
    texture2d<float, access::write> output [[texture(0)]],
    constant FluidUniforms &u [[buffer(0)]],
    uint2 gid [[thread_position_in_grid]])
{
    if (gid.x >= output.get_width() || gid.y >= output.get_height()) return;

    // Y-flip: Metal texture origin is top-left.
    float2 uv = float2(gid) / u.resolution;
    uv.y = 1.0 - uv.y;

    // TODO: replace stub gradient with the actual scene visual.
    // FBM-based stub: animated noise tinted with the scene's gradient.
    float n = __scene___fbm(uv * 4.0 + u.time * 0.1, 4);
    float3 color = mix(float3(0.05, 0.1, 0.2), u.tint, n);

    // Touch reactivity: brighten near touch position when active.
    if (u.touchActive > 0.5) {
        float2 touchUV = u.touch / u.resolution;
        touchUV.y = 1.0 - touchUV.y;
        float d = distance(uv, touchUV);
        color += float3(1.0) * exp(-d * 8.0) * 0.4;
    }

    output.write(float4(color, 1.0), gid);
}
